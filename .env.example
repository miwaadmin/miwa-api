# Miwa server environment
# Copy this to .env and fill in your real values.

# Core server
JWT_SECRET=replace-me
PORT=3001
CORS_ORIGIN=http://localhost:3000
APP_BASE_URL=https://miwa.care
DB_PATH=./mftbrain.db

# Azure OpenAI (all AI traffic routes through this Azure deployment)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_KEY=replace-me
AZURE_OPENAI_DEPLOYMENT=gpt-main

# Twilio SMS
# Option A: API key auth (recommended for new Twilio projects)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=replace-me

# Option B: legacy auth token (leave blank if using API key auth)
TWILIO_AUTH_TOKEN=replace-me

# Sender / routing
TWILIO_PHONE_NUMBER=+15555550123
# Optional: use a Twilio Messaging Service instead of a single sender number
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
